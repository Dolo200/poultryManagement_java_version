<?xml version="1.0" encoding="UTF-8"?>
<persistence version="3.0" xmlns="https://jakarta.ee/xml/ns/persistence" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd">
  <!-- Define Persistence Unit -->
  <persistence-unit name="my_persistence_unit" transaction-type="JTA">
    <jta-data-source>schoolDB</jta-data-source>
    <class>models.AiChat</class>
    <class>models.Alert</class>
    <class>models.ChickenGroup</class>
    <class>models.CommunityChat</class>
    <class>models.InventoryProduct</class>
    <class>models.Mortality</class>
    <class>models.Notification</class>
    <class>models.Orders</class>
    <class>models.Payment</class>
    <class>models.Postedgood</class>
    <class>models.PoultryFarm</class>
    <class>models.Report</class>
    <class>models.Student</class>
    <class>models.Users</class>
    <class>models.Vaccination</class>
    <class>models.FarmStaff</class>
    <class>models.FeedConsumption</class>
    <exclude-unlisted-classes>true</exclude-unlisted-classes>
  </persistence-unit>
</persistence>
